{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "backup/**",
      "public/**",
      "package.json",
      "package-lock.json",
      "server.js",
      "server.py",
      "firebase-deploy.log",
      "*.bat",
      "*.md",
      "skills-lock.json"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
